{
  "type": "bubble",
  "size": "mega",
  "body": {
    "type": "box",
    "layout": "vertical",
    "spacing": "md",
    "contents": [
      { "type": "text", "text": "Cost Estimate by B/L", "weight": "bold", "size": "md" },
      { "type": "text", "text": "{{bl_no}}", "weight": "bold", "size": "xl", "margin": "sm" },
      { "type": "separator", "margin": "md" },

      { "type": "text", "text": "Paid Through Date: {{date_time}}", "size": "sm" },
      { "type": "text", "text": "Company Name: {{company_name}}", "size": "sm" },
      { "type": "text", "text": "Terminal Code: {{terminal_code}}", "size": "sm" },

      { "type": "separator", "margin": "md" },
      { "type": "text", "text": "Summary (THB)", "weight": "bold", "size": "sm" },
      { "type": "text", "text": "Total: {{total_thb}}", "size": "sm" },
      { "type": "text", "text": "VAT: {{vat_thb}}", "size": "sm" },
      { "type": "text", "text": "WHT: {{wht_thb}}", "size": "sm" },
      { "type": "text", "text": "Sub Total: {{sub_total_thb}}", "size": "sm" },
      { "type": "text", "text": "Grand Total: {{grand_total_thb}}", "weight": "bold", "size": "md", "margin": "sm" }
    ]
  },
  "footer": {
    "type": "box",
    "layout": "vertical",
    "spacing": "sm",
    "contents": [
      {
        "type": "button",
        "style": "primary",
        "action": {
          "type": "uri",
          "label": "More Details",
          "uri": "https://online.hutchisonports.co.th/"
        }
      },
      {
        "type": "button",
        "style": "secondary",
        "action": {
          "type": "postback",
          "label": "Check Another B/L",
          "data": "action=cost"
        }
      }
    ]
  }
}